# NewsAPI - free tier key from https://newsapi.org
# Required for the company news enrichment and 10-pt score bonus
NEWS_API_KEY=your_newsapi_key_here

# Census API: no key needed (https://api.census.gov)
# Wikipedia API: no key needed

# Scheduler config (used by server.ts + /api/schedule)
# Cron expression for scheduled runs (default: daily at 9 AM)
CRON_SCHEDULE=0 9 * * *

# Absolute path to the CSV file to process on scheduled runs
# Example: SCHEDULED_CSV_PATH=/Users/you/leads.csv
SCHEDULED_CSV_PATH=

# Optional: shared secret to protect the /api/schedule endpoint
CRON_SECRET=
